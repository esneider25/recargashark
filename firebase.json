{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": [
    {
      "target": "store",
      "public": ".",
      "cleanUrls": true,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "admin",
      "public": ".",
      "cleanUrls": true,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/",
          "destination": "/admin.html"
        }
      ]
    }
  ]
}
