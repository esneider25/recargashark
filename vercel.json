{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/__/auth/:match*",
      "destination": "https://recargashark.firebaseapp.com/__/auth/:match*"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "admin.recargashark.com"
        }
      ],
      "destination": "/admin.html"
    }
  ]
}
