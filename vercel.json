{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "admin.recargashark.com"
        }
      ],
      "destination": "/admin",
      "permanent": true
    },
    {
      "source": "/servicio(.*)",
      "destination": "/",
      "permanent": true
    }
  ]
}
