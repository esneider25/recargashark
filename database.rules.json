{
  "rules": {
    "products": { ".read": true },
    "categories": { ".read": true },
    "exchange_rate": { ".read": true },
    "payment_methods": { ".read": true },
    "settings": { ".read": true },
    "messages": { ".read": true, ".write": true },
    "orders": { 
      ".read": "auth != null && auth.token.email === 'adminshark@gmail.com'",
      ".write": true,
      "$orderId": {
        ".read": "auth != null && auth.token.email === 'adminshark@gmail.com' || (auth != null && data.child('userId').val() === auth.uid) || (!data.hasChild('userId') || data.child('userId').val() == null)"
      }
    },
    "telegram_config": { ".read": true },
    "discounts": { ".read": true },
    "spam_tracker": { ".read": true, ".write": true },
    "order_counter": { ".read": true },
    "api_configs": { ".read": "auth != null && auth.token.email === 'adminshark@gmail.com'" },
    "users": {
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || auth.token.email === 'adminshark@gmail.com')",
        ".write": "auth != null && ($uid === auth.uid || auth.token.email === 'adminshark@gmail.com')"
      }
    },
    ".read": "auth != null && auth.token.email === 'adminshark@gmail.com'",
    ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
  }
}
