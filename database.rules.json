{
  "rules": {
    "products": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "categories": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "exchange_rate": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "payment_methods": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "settings": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "landing_config": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "banners": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "messages": { 
      ".read": "true", 
      ".write": "true" 
    },
    "orders": { 
      ".read": "auth != null",
      ".write": "auth != null",
      "$orderId": {
        ".read": "true",
        ".write": "!data.exists() || auth != null",
        "roulettePlayed": {
          ".write": "true"
        }
      }
    },
    "telegram_config": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "discounts": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "spam_tracker": { 
      ".read": "true", 
      ".write": "true" 
    },
    "order_counter": { 
      ".read": "true", 
      ".write": "auth != null" 
    },
    "api_configs": { 
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null",
        "role": {
          ".validate": "!data.exists() || data.val() == newData.val() || auth.token.email === 'adminshark@gmail.com' || (data.val() === 'influencer' && newData.val() === 'partner')"
        },
        "discountPercentage": {
          ".validate": "!data.exists() || data.val() == newData.val() || auth.token.email === 'adminshark@gmail.com'"
        },
        "isBlocked": {
          ".validate": "!data.exists() || data.val() == newData.val() || auth.token.email === 'adminshark@gmail.com'"
        }
      }
    }
  }
}