{
  "rules": {
    "products": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "categories": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "exchange_rate": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "payment_methods": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "settings": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "landing_config": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "banners": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "messages": { 
      ".read": "auth != null && auth.token.email === 'adminshark@gmail.com'",
      "$sessionId": {
         ".read": "(auth != null && (auth.token.email === 'adminshark@gmail.com' || auth.uid === $sessionId)) || $sessionId.matches(/^fp-/)",
         ".write": "(auth != null && (auth.token.email === 'adminshark@gmail.com' || auth.uid === $sessionId)) || ($sessionId.matches(/^fp-/) && newData.exists())"
      }
    },
    "orders": { 
      ".read": "auth != null && (auth.token.email === 'adminshark@gmail.com' || (query.orderByChild == 'userId' && query.equalTo == auth.uid))",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'",
      ".indexOn": ["userId", "id"],
      "$orderId": {
        ".read": "!$orderId.beginsWith('AP-OLD-') || (auth != null && data.child('userId').val() === auth.uid) || (auth != null && auth.token.email === 'adminshark@gmail.com')",
        ".write": "auth != null && auth.token.email === 'adminshark@gmail.com' || (!data.exists() && newData.child('status').val() === 'pending' && (auth == null || newData.child('userId').val() === auth.uid)) || (data.exists() && (newData.child('status').val() === data.child('status').val() || (data.child('status').val() === 'invalid-id' && newData.child('status').val() === 'pending')) && newData.child('priceUsd').val() === data.child('priceUsd').val() && newData.child('priceBs').val() === data.child('priceBs').val() && (auth == null || data.child('userId').val() === auth.uid))",
        "roulettePlayed": {
          ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
        }
      }
    },
    "withdrawals": {
      ".read": "auth != null && (auth.token.email === 'adminshark@gmail.com' || (query.orderByChild == 'userId' && query.equalTo == auth.uid))",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'",
      ".indexOn": ["userId"],
      "$wdId": {
         ".read": "auth != null && (data.child('userId').val() === auth.uid || auth.token.email === 'adminshark@gmail.com')",
         ".write": "auth != null && ((!data.exists() && newData.child('userId').val() === auth.uid && newData.child('status').val() === 'pending') || auth.token.email === 'adminshark@gmail.com')"
      }
    },
    "telegram_config": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "discounts": { 
      ".read": "true",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "_sysTracking": {
      ".read": "auth != null && auth.token.email === 'adminshark@gmail.com'",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "admin_logs": {
      ".read": "auth != null && auth.token.email === 'adminshark@gmail.com'",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "spam_tracker": { 
      ".read": "auth != null && auth.token.email === 'adminshark@gmail.com'", 
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'" 
    },
    "order_counter": { 
      ".read": "true", 
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'" 
    },
    "api_configs": { 
      ".read": "auth != null && auth.token.email === 'adminshark@gmail.com'",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'"
    },
    "users": {
      ".read": "auth != null && auth.token.email === 'adminshark@gmail.com'",
      ".write": "auth != null && auth.token.email === 'adminshark@gmail.com'",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && (auth.uid === $uid || auth.token.email === 'adminshark@gmail.com')",
        "role": {
          ".validate": "!data.exists() || data.val() == newData.val() || auth.token.email === 'adminshark@gmail.com' || (data.val() === 'influencer' && newData.val() === 'partner')"
        },
        "discountPercentage": {
          ".validate": "!data.exists() || data.val() == newData.val() || auth.token.email === 'adminshark@gmail.com'"
        },
        "isBlocked": {
          ".validate": "!data.exists() || data.val() == newData.val() || auth.token.email === 'adminshark@gmail.com'"
        },
        "wallet": {
          ".validate": "!data.exists() || data.val() == newData.val() || auth.token.email === 'adminshark@gmail.com'"
        },
        "points": {
          ".validate": "!data.exists() || data.val() == newData.val() || auth.token.email === 'adminshark@gmail.com'"
        },
        "totalSpent": {
          ".validate": "!data.exists() || data.val() == newData.val() || auth.token.email === 'adminshark@gmail.com'"
        },
        "referralsCount": {
          ".validate": "!data.exists() || data.val() == newData.val() || auth.token.email === 'adminshark@gmail.com'"
        },
        "referralsEarnedPoints": {
          ".validate": "!data.exists() || data.val() == newData.val() || auth.token.email === 'adminshark@gmail.com'"
        },
        "hasMadeFirstPurchase": {
          ".validate": "!data.exists() || data.val() == newData.val() || auth.token.email === 'adminshark@gmail.com'"
        },
        "referredBy": {
          ".validate": "!data.exists() || data.val() == newData.val() || newData.val() == null || auth.token.email === 'adminshark@gmail.com'"
        },
        "referralCode": {
          ".validate": "!data.exists() || data.val() == newData.val() || auth.token.email === 'adminshark@gmail.com'"
        },
        "referralLimit": {
          ".validate": "!data.exists() || data.val() == newData.val() || auth.token.email === 'adminshark@gmail.com'"
        },
        "autoProcess": {
          ".validate": "!data.exists() || data.val() == newData.val() || auth.token.email === 'adminshark@gmail.com'"
        }
      }
    }
  }
}